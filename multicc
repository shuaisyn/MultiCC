#!/bin/bash
# MultiCC service manager — start/stop/restart/log
# Usage: ./multicc start|stop|restart|status|log|install|uninstall

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LABEL="com.multicc.server"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
LOG_DIR="$SCRIPT_DIR/logs"
OUT_LOG="$LOG_DIR/multicc.log"
ERR_LOG="$LOG_DIR/multicc-error.log"
PID_FILE="$SCRIPT_DIR/.multicc.pid"
NODE="/opt/homebrew/bin/node"

mkdir -p "$LOG_DIR"

# ── Helpers ──
is_running() {
  if [ -f "$PID_FILE" ]; then
    local pid=$(cat "$PID_FILE" 2>/dev/null)
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
  fi
  # Also check by process
  pgrep -f "node $SCRIPT_DIR/server.js" >/dev/null 2>&1
}

get_pid() {
  if [ -f "$PID_FILE" ]; then
    cat "$PID_FILE" 2>/dev/null
    return
  fi
  pgrep -f "node $SCRIPT_DIR/server.js" 2>/dev/null | head -1
}

do_start() {
  if is_running; then
    echo "MultiCC is already running (PID $(get_pid))"
    return 1
  fi
  echo "Starting MultiCC..."
  cd "$SCRIPT_DIR"
  nohup "$NODE" server.js >> "$OUT_LOG" 2>> "$ERR_LOG" &
  local pid=$!
  echo $pid > "$PID_FILE"
  sleep 1
  if kill -0 $pid 2>/dev/null; then
    echo "MultiCC started (PID $pid)"
    echo "Log: $OUT_LOG"
  else
    echo "Failed to start. Check $ERR_LOG"
    rm -f "$PID_FILE"
    return 1
  fi
}

do_stop() {
  if ! is_running; then
    echo "MultiCC is not running"
    rm -f "$PID_FILE"
    return 0
  fi
  local pid=$(get_pid)
  echo "Stopping MultiCC (PID $pid)..."
  kill "$pid" 2>/dev/null
  # Wait up to 5 seconds for graceful shutdown
  for i in $(seq 1 10); do
    if ! kill -0 "$pid" 2>/dev/null; then
      break
    fi
    sleep 0.5
  done
  # Force kill if still alive
  if kill -0 "$pid" 2>/dev/null; then
    kill -9 "$pid" 2>/dev/null
  fi
  rm -f "$PID_FILE"
  echo "MultiCC stopped"
}

do_restart() {
  do_stop
  sleep 1
  do_start
}

do_status() {
  if is_running; then
    echo "MultiCC is running (PID $(get_pid))"
  else
    echo "MultiCC is not running"
  fi
}

do_log() {
  if [ ! -f "$OUT_LOG" ]; then
    echo "No log file yet"
    return
  fi
  tail -f "$OUT_LOG" "$ERR_LOG"
}

do_install() {
  # Lay down every bundled skill so claude sessions can discover them immediately
  # (the server also re-syncs these on every startup). Any dir under skills/ that
  # contains a SKILL.md is installed — no need to list them here.
  if [ -d "$SCRIPT_DIR/skills" ]; then
    mkdir -p "$HOME/.claude/skills"
    for SKILL_SRC in "$SCRIPT_DIR"/skills/*/; do
      [ -f "$SKILL_SRC/SKILL.md" ] || continue
      SKILL_NAME="$(basename "$SKILL_SRC")"
      SKILL_DEST="$HOME/.claude/skills/$SKILL_NAME"
      rm -rf "$SKILL_DEST"
      cp -R "$SKILL_SRC" "$SKILL_DEST"
      chmod +x "$SKILL_DEST"/bin/* 2>/dev/null || true
      echo "Installed skill → $SKILL_DEST"
    done
  fi

  # Create launchd plist for auto-start on login
  cat > "$PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$LABEL</string>
  <key>ProgramArguments</key>
  <array>
    <string>$NODE</string>
    <string>$SCRIPT_DIR/server.js</string>
  </array>
  <key>WorkingDirectory</key>
  <string>$SCRIPT_DIR</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>$OUT_LOG</string>
  <key>StandardErrorPath</key>
  <string>$ERR_LOG</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
</dict>
</plist>
EOF
  # Stop if already loaded
  launchctl unload "$PLIST" 2>/dev/null
  launchctl load "$PLIST"
  echo "MultiCC installed as login service"
  echo "  Auto-starts on login, auto-restarts on crash"
  echo "  Plist: $PLIST"
  echo ""
  echo "  ./multicc restart   — restart service"
  echo "  ./multicc stop      — stop (will auto-restart via KeepAlive)"
  echo "  ./multicc uninstall — remove auto-start"
}

do_uninstall() {
  if [ -f "$PLIST" ]; then
    launchctl unload "$PLIST" 2>/dev/null
    rm -f "$PLIST"
    echo "MultiCC service uninstalled"
  else
    echo "MultiCC service not installed"
  fi
  # Also kill any running instance
  do_stop
}

# ── Main ──
case "${1:-}" in
  start)     do_start ;;
  stop)      do_stop ;;
  restart)   do_restart ;;
  status)    do_status ;;
  log|logs)  do_log ;;
  install)   do_install ;;
  uninstall) do_uninstall ;;
  *)
    echo "MultiCC service manager"
    echo ""
    echo "Usage: ./multicc <command>"
    echo ""
    echo "Commands:"
    echo "  start      Start MultiCC server"
    echo "  stop       Stop MultiCC server"
    echo "  restart    Restart MultiCC server"
    echo "  status     Check if running"
    echo "  log        Tail live logs"
    echo "  install    Install as login service (auto-start + auto-restart)"
    echo "  uninstall  Remove login service"
    ;;
esac
