#!/bin/bash
# MultiCC service manager — start/stop/restart/log
# Usage: ./multicc start|stop|restart|status|log|update|install|uninstall

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LABEL="com.multicc.server"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
LOG_DIR="$SCRIPT_DIR/logs"
OUT_LOG="$LOG_DIR/multicc.log"
ERR_LOG="$LOG_DIR/multicc-error.log"
PID_FILE="$SCRIPT_DIR/.multicc.pid"

# Resolve the node binary. Auto-detect from PATH (covers Homebrew on both
# Apple Silicon and Intel, nvm/fnm, system installs); fall back to the common
# install locations. Override with MULTICC_NODE=/path/to/node if needed.
if [ -n "${MULTICC_NODE:-}" ] && [ -x "${MULTICC_NODE:-}" ]; then
  NODE="$MULTICC_NODE"
elif command -v node >/dev/null 2>&1; then
  NODE="$(command -v node)"
else
  NODE=""
  for _n in /opt/homebrew/bin/node /usr/local/bin/node /usr/bin/node; do
    [ -x "$_n" ] && NODE="$_n" && break
  done
fi
if [ -z "$NODE" ] || [ ! -x "$NODE" ]; then
  echo "Error: could not find a 'node' binary. Install Node.js >= 18," >&2
  echo "       or set MULTICC_NODE=/full/path/to/node and retry." >&2
  exit 1
fi

mkdir -p "$LOG_DIR"

# ── Helpers ──
is_running() {
  if [ -f "$PID_FILE" ]; then
    local pid=$(cat "$PID_FILE" 2>/dev/null)
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
  fi
  # Also check by process
  pgrep -f "node $SCRIPT_DIR/server.js" >/dev/null 2>&1
}

get_pid() {
  if [ -f "$PID_FILE" ]; then
    cat "$PID_FILE" 2>/dev/null
    return
  fi
  pgrep -f "node $SCRIPT_DIR/server.js" 2>/dev/null | head -1
}

do_start() {
  if is_running; then
    echo "MultiCC is already running (PID $(get_pid))"
    return 1
  fi
  echo "Starting MultiCC..."
  cd "$SCRIPT_DIR"
  nohup "$NODE" server.js >> "$OUT_LOG" 2>> "$ERR_LOG" &
  local pid=$!
  echo $pid > "$PID_FILE"
  sleep 1
  if kill -0 $pid 2>/dev/null; then
    echo "MultiCC started (PID $pid)"
    echo "Log: $OUT_LOG"
  else
    echo "Failed to start. Check $ERR_LOG"
    rm -f "$PID_FILE"
    return 1
  fi
}

do_stop() {
  if ! is_running; then
    echo "MultiCC is not running"
    rm -f "$PID_FILE"
    return 0
  fi
  local pid=$(get_pid)
  echo "Stopping MultiCC (PID $pid)..."
  kill "$pid" 2>/dev/null
  # Wait up to 5 seconds for graceful shutdown
  for i in $(seq 1 10); do
    if ! kill -0 "$pid" 2>/dev/null; then
      break
    fi
    sleep 0.5
  done
  # Force kill if still alive
  if kill -0 "$pid" 2>/dev/null; then
    kill -9 "$pid" 2>/dev/null
  fi
  rm -f "$PID_FILE"
  echo "MultiCC stopped"
}

do_restart() {
  do_stop
  sleep 1
  do_start
}

do_status() {
  if is_running; then
    echo "MultiCC is running (PID $(get_pid))"
  else
    echo "MultiCC is not running"
  fi
}

do_log() {
  if [ ! -f "$OUT_LOG" ]; then
    echo "No log file yet"
    return
  fi
  tail -f "$OUT_LOG" "$ERR_LOG"
}

do_update() {
  cd "$SCRIPT_DIR" || { echo "Cannot cd to $SCRIPT_DIR"; return 1; }

  if [ ! -d .git ]; then
    echo "Not a git checkout ($SCRIPT_DIR) — cannot self-update."
    echo "Re-run the install script to update."
    return 1
  fi

  # Refuse to clobber local changes
  if [ -n "$(git status --porcelain 2>/dev/null)" ]; then
    echo "Working tree has local changes — aborting to avoid overwriting them."
    echo "Commit or stash your changes, then run './multicc update' again."
    return 1
  fi

  local branch before after
  branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"
  before="$(git rev-parse HEAD 2>/dev/null)"

  echo "Updating MultiCC (branch: $branch)..."
  if ! git pull --ff-only origin "$branch"; then
    echo "git pull failed (not a fast-forward, or network issue) — resolve manually and retry."
    return 1
  fi

  after="$(git rev-parse HEAD 2>/dev/null)"
  if [ "$before" = "$after" ]; then
    echo "Already up to date — nothing to restart."
    return 0
  fi

  # Reinstall deps only when the dependency manifests actually changed
  if git diff --name-only "$before" "$after" | grep -qE '^package(-lock)?\.json$'; then
    echo "Dependencies changed — running npm install..."
    if ! npm install 2>&1; then
      echo "npm install failed — fix the error above, then re-run './multicc update'."
      return 1
    fi
  fi

  echo "Restarting to apply update..."
  if [ -f "$PLIST" ]; then
    # Installed as a launchd service — reload so the new server.js is picked up
    launchctl unload "$PLIST" 2>/dev/null
    launchctl load "$PLIST"
    echo "Service reloaded."
  else
    do_restart
  fi
  echo "Update complete (${before:0:7} → ${after:0:7})."
}

do_install() {
  # Lay down every bundled skill so claude sessions can discover them immediately
  # (the server also re-syncs these on every startup). Any dir under skills/ that
  # contains a SKILL.md is installed — no need to list them here.
  if [ -d "$SCRIPT_DIR/skills" ]; then
    mkdir -p "$HOME/.claude/skills"
    for SKILL_SRC in "$SCRIPT_DIR"/skills/*/; do
      [ -f "$SKILL_SRC/SKILL.md" ] || continue
      SKILL_NAME="$(basename "$SKILL_SRC")"
      SKILL_DEST="$HOME/.claude/skills/$SKILL_NAME"
      rm -rf "$SKILL_DEST"
      cp -R "$SKILL_SRC" "$SKILL_DEST"
      chmod +x "$SKILL_DEST"/bin/* 2>/dev/null || true
      echo "Installed skill → $SKILL_DEST"
    done
  fi

  # Create launchd plist for auto-start on login
  cat > "$PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$LABEL</string>
  <key>ProgramArguments</key>
  <array>
    <string>$NODE</string>
    <string>$SCRIPT_DIR/server.js</string>
  </array>
  <key>WorkingDirectory</key>
  <string>$SCRIPT_DIR</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>$OUT_LOG</string>
  <key>StandardErrorPath</key>
  <string>$ERR_LOG</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>$(dirname "$NODE"):/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
</dict>
</plist>
EOF
  # Stop if already loaded
  launchctl unload "$PLIST" 2>/dev/null
  launchctl load "$PLIST"
  echo "MultiCC installed as login service"
  echo "  Auto-starts on login, auto-restarts on crash"
  echo "  Plist: $PLIST"
  echo ""
  echo "  ./multicc restart   — restart service"
  echo "  ./multicc stop      — stop (will auto-restart via KeepAlive)"
  echo "  ./multicc uninstall — remove auto-start"
}

do_uninstall() {
  if [ -f "$PLIST" ]; then
    launchctl unload "$PLIST" 2>/dev/null
    rm -f "$PLIST"
    echo "MultiCC service uninstalled"
  else
    echo "MultiCC service not installed"
  fi
  # Also kill any running instance
  do_stop
}

# ── Main ──
case "${1:-}" in
  start)     do_start ;;
  stop)      do_stop ;;
  restart)   do_restart ;;
  status)    do_status ;;
  log|logs)  do_log ;;
  update)    do_update ;;
  install)   do_install ;;
  uninstall) do_uninstall ;;
  *)
    echo "MultiCC service manager"
    echo ""
    echo "Usage: ./multicc <command>"
    echo ""
    echo "Commands:"
    echo "  start      Start MultiCC server"
    echo "  stop       Stop MultiCC server"
    echo "  restart    Restart MultiCC server"
    echo "  status     Check if running"
    echo "  log        Tail live logs"
    echo "  update     Pull latest code, reinstall deps if needed, restart"
    echo "  install    Install as login service (auto-start + auto-restart)"
    echo "  uninstall  Remove login service"
    ;;
esac
